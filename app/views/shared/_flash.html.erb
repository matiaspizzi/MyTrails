  <% flash.each do |type, message| %>
  <% flash_class = case type
         when "notice" then "text-secondary border-secondary"
         when "alert" then "text-red-400 border-red-400"
         else "text-gray-400 border-gray-400"
       end %>
  <div class="flash bg-tertiary border-r-4 p-4 mb-4 fixed top-[70px] right-2 flex align-middle justify-between <%= flash_class %>"
       data-controller="flash">
    <p><%= message %></p>
    <button class="px-4" data-action="click->flash#dismiss">x</button>
  </div>
  <% end %>
